---
layout: base.njk
title: Saved Finds — FindsRadar
---

<section class="max-w-7xl mx-auto px-4 pt-10 pb-16">

  <div class="mb-8">
    <h1 class="text-2xl font-bold text-slate-900 dark:text-white mb-1">Saved finds</h1>
    <p class="text-sm text-slate-500 dark:text-slate-400">
      Items you've hearted. Stored in your browser — clears if you clear cookies.
    </p>
  </div>

  <div id="wishlist-grid" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4" style="display:none;"></div>

  <div id="wishlist-empty" class="py-24 text-center" style="display:none;">
    <svg class="w-10 h-10 mx-auto mb-4 text-slate-300 dark:text-slate-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
    </svg>
    <p class="text-slate-500 dark:text-slate-400 text-sm mb-4">No saved finds yet.</p>
    <a href="/" class="inline-block px-5 py-2.5 bg-brand hover:bg-brand-hover text-white text-sm font-bold rounded-xl transition-colors">Browse finds →</a>
  </div>

</section>

<script>
(function () {
  function getCookie(name) {
    var m = document.cookie.match('(?:^|; )' + name.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + '=([^;]*)');
    return m ? m[1] : null;
  }
  function getWishlist() {
    try { return JSON.parse(decodeURIComponent(getCookie('findsradar_wishlist') || '[]')); }
    catch (e) { return []; }
  }

  function esc(str) {
    return (str || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function buildCard(p) {
    var safeJson = JSON.stringify(p)
      .replace(/\\/g, '\\\\')
      .replace(/'/g, "\\'")
      .replace(/</g, '\\u003c')
      .replace(/>/g, '\\u003e');

    var imgHtml = (p.media && p.media[0])
      ? '<img src="' + esc(p.media[0].url) + '" alt="' + esc(p.name) + '" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy">'
      : '<div class="w-full h-full bg-slate-100 dark:bg-slate-700 flex items-center justify-center text-xs text-slate-400 dark:text-slate-500">No Image</div>';

    var badge = p.marketplace
      ? '<span class="text-xs text-slate-400 dark:text-slate-500 font-medium truncate">' + esc(p.marketplace.display_name || p.marketplace.name) + (p.country ? ' · ' + esc(p.country.name) : '') + '</span>'
      : '';

    var cta = p.affiliate_link
      ? '<a href="' + esc(p.affiliate_link) + '" target="_blank" rel="noopener noreferrer sponsored" class="mt-auto pt-1.5 block text-center text-xs font-bold py-2 px-3 bg-brand hover:bg-brand-hover text-white rounded-lg transition-colors">View deal →</a>'
      : '';

    return '<div class="product-card group relative rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 shadow-sm hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200 overflow-hidden flex flex-col"'
      + ' data-id="' + esc(p._id) + '"'
      + ' data-name="' + esc((p.name || '').toLowerCase()) + '"'
      + ' data-marketplace="' + esc(p.marketplace ? p.marketplace.slug : '') + '">'
      + '<div class="cursor-pointer relative overflow-hidden flex-shrink-0" style="aspect-ratio:1/1" onclick=\'openModal(\'' + safeJson + '\')\'>'
      + imgHtml
      + '<button class="wishlist-btn absolute top-2 right-2 z-10 w-7 h-7 flex items-center justify-center rounded-full bg-white/85 dark:bg-slate-900/85 backdrop-blur-sm shadow hover:scale-110 transition-transform"'
      + ' data-id="' + esc(p._id) + '" aria-label="Remove from wishlist"'
      + ' onclick="toggleWishlist(event,\'' + esc(p._id) + '\')">'
      + '<svg class="heart-icon is-active w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>'
      + '</button>'
      + '</div>'
      + '<div class="p-3 flex flex-col gap-1.5 flex-1">'
      + badge
      + '<button class="text-left text-sm font-semibold text-slate-800 dark:text-white line-clamp-2 hover:text-brand dark:hover:text-brand-hover transition-colors" onclick=\'openModal(\'' + safeJson + '\')\'>' + esc(p.name) + '</button>'
      + cta
      + '</div>'
      + '</div>';
  }

  function refresh() {
    var ids = getWishlist();
    var all = window.__FINDSRADAR_PRODUCTS || [];
    var saved = all.filter(function (p) { return ids.indexOf(p._id) !== -1; });
    var grid = document.getElementById('wishlist-grid');
    var empty = document.getElementById('wishlist-empty');

    if (!saved.length) {
      grid.style.display = 'none';
      empty.style.display = 'block';
      return;
    }
    grid.innerHTML = saved.map(buildCard).join('');
    grid.style.display = 'grid';
    empty.style.display = 'none';

    // Remove card from grid when unhearted here
    grid.querySelectorAll('.wishlist-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var cardId = btn.dataset.id;
        setTimeout(function () {
          if (getWishlist().indexOf(cardId) === -1) {
            var card = grid.querySelector('[data-id="' + cardId + '"]');
            if (card) card.remove();
            if (!grid.querySelector('.product-card')) {
              grid.style.display = 'none';
              empty.style.display = 'block';
            }
          }
        }, 0);
      });
    });
  }

  document.addEventListener('DOMContentLoaded', refresh);
})();
</script>
