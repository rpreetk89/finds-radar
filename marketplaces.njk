---
layout: base.njk
title: All Marketplaces
permalink: /marketplaces/index.html
---

<div class="max-w-7xl mx-auto px-4 py-8 text-slate-900 dark:text-white">
  <h1 class="text-3xl font-bold mb-8">All Marketplaces</h1>
  
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {# Make sure you are iterating over the collection directly #}
    {% for group in collections.marketplaceGroups %}
      <div class="p-6 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl shadow-sm hover:shadow-md transition">
        <h2 class="text-xl font-bold mb-4 capitalize">{{ group.name }}</h2>
        
        {# Ensure the link uses the variable from the loop #}
        <a href="/marketplaces/{{ group.name | slugify }}/" 
           class="text-indigo-600 dark:text-indigo-400 font-semibold hover:underline">
           Browse {{ group.name }} →
        </a>
      </div>
    {% endfor %}
  </div>
</div>