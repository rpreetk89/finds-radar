---
pagination:
  data: collections.countryMarketplacePages
  size: 1
  alias: page
permalink: "/{{ page.countryCode }}/marketplaces/{{ page.marketplace.slug }}/index.html"
layout: base.njk
eleventyComputed:
  title: "FindsRadar — {{ page.marketplace.name }}"
---

<div class="max-w-7xl mx-auto px-4 py-8 text-slate-900 dark:text-white">
  <a href="/{{ page.countryCode }}/" class="inline-flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400 hover:text-brand dark:hover:text-brand-hover mb-6 transition-colors">
    ←
    <img src="https://flagcdn.com/w20/{{ page.countryCode }}.png"
         srcset="https://flagcdn.com/w40/{{ page.countryCode }}.png 2x"
         alt="{{ page.countryName }}"
         class="w-5 h-3.5 object-cover rounded-sm">
    {{ page.countryName }}
  </a>

  <div class="flex items-center gap-3 mb-2">
    {% if page.marketplace.domain %}
      <img
        src="https://www.google.com/s2/favicons?domain={{ page.marketplace.domain }}&sz=128"
        alt="{{ page.marketplace.name }}"
        class="h-8 w-auto rounded"
        onerror="this.style.display='none'"
      >
    {% endif %}
    <h1 class="text-3xl font-bold capitalize">{{ page.marketplace.name }}</h1>
  </div>
  <p class="text-slate-500 dark:text-slate-400 mb-8">Browse categories on {{ page.marketplace.name }}</p>

  {% set categoryBaseUrl = '/' + page.countryCode + '/categories/' %}
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
    {% for catName, items in page.marketplace.categories %}
      {% set productList = items %}
      {% include "category-card.njk" %}
    {% else %}
      <p class="text-slate-500 col-span-4">No products yet for this marketplace.</p>
    {% endfor %}
  </div>
</div>
