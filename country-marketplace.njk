---
pagination:
  data: collections.countryMarketplacePages
  size: 1
  alias: page
permalink: "/{{ page.countryCode }}/marketplaces/{{ page.marketplace.slug }}/index.html"
layout: base.njk
eleventyComputed:
  title: "FindsRadar — {{ page.marketplace.name }}"
---

<div class="max-w-7xl mx-auto px-4 py-8 text-slate-900 dark:text-white">
  <a href="/{{ page.countryCode }}/" class="inline-flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400 hover:text-orange-500 dark:hover:text-orange-400 mb-6 transition-colors">
    ←
    <img src="https://flagcdn.com/w20/{{ page.countryCode }}.png"
         srcset="https://flagcdn.com/w40/{{ page.countryCode }}.png 2x"
         alt="{{ page.countryName }}"
         class="w-5 h-3.5 object-cover rounded-sm">
    {{ page.countryName }}
  </a>

  <h1 class="text-3xl font-bold mb-8 capitalize">{{ page.marketplace.name }}</h1>

  <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-6">
    {% for catName, items in page.marketplace.categories %}
      <div class="p-6 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl shadow-sm hover:shadow-md transition">
        <h3 class="text-xl font-bold capitalize mb-4">{{ catName }}</h3>
        <div class="grid grid-cols-2 gap-2">
          {% for product in items | limit(4) %}
            {% include "product-card.njk" %}
          {% endfor %}
        </div>
      </div>
    {% else %}
      <p class="text-slate-500 col-span-4">No products yet for this marketplace.</p>
    {% endfor %}
  </div>
</div>
