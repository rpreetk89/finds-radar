{# _includes/product-card.njk — Rich product card for grids #}
{# Requires: product object with _id, name, description, categories, marketplace, country, media, affiliate_link #}
{% if product %}
<div
  class="product-card group relative rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 shadow-sm hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200 overflow-hidden flex flex-col"
  data-name="{{ product.name | lower }}"
  data-description="{{ (product.description or '') | lower }}"
  data-categories="{{ (product.categories or []) | join(',') | lower }}"
  data-marketplace="{{ product.marketplace.slug if product.marketplace else '' }}"
  data-marketplace-name="{{ (product.marketplace.display_name or product.marketplace.name) if product.marketplace else '' }}"
>

  {# ── Image (click → modal) ── #}
  <div
    class="cursor-pointer relative overflow-hidden flex-shrink-0"
    style="aspect-ratio:1/1"
    onclick="openModalById('{{ product._id }}')"
  >
    {% if product.media and product.media[0] %}
      <img
        src="{{ product.media[0].url }}"
        alt="{{ product.name }}"
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
      >
      {# Zoom hint — the modal shows the full, uncropped image; this signals it's one click away #}
      <div class="absolute inset-0 flex items-center justify-center bg-black/0 group-hover:bg-black/10 transition-colors pointer-events-none">
        <div class="w-8 h-8 rounded-full bg-white/90 dark:bg-slate-900/90 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity shadow">
          <svg class="w-4 h-4 text-slate-700 dark:text-slate-200" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 8V4h4M20 8V4h-4M4 16v4h4M20 16v4h-4"/>
          </svg>
        </div>
      </div>
    {% else %}
      <div class="w-full h-full bg-slate-100 dark:bg-slate-700 flex items-center justify-center text-xs text-slate-400 dark:text-slate-500">
        No Image
      </div>
    {% endif %}

    {# Wishlist heart — stopPropagation prevents modal from opening #}
    <button
      class="wishlist-btn absolute top-2 right-2 z-10 w-7 h-7 flex items-center justify-center rounded-full bg-white/85 dark:bg-slate-900/85 backdrop-blur-sm shadow hover:scale-110 transition-transform"
      data-id="{{ product._id }}"
      aria-label="Save to wishlist"
      onclick="toggleWishlist(event, '{{ product._id }}')"
    >
      <svg class="heart-icon w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
      </svg>
    </button>
  </div>

  {# ── Card body ── #}
  <div class="p-3 flex flex-col gap-1.5 flex-1">

    {# Marketplace logo badge — DATA-SOURCE: sanity #}
    {% if product.marketplace and product.marketplace.domain %}
      <button
        type="button"
        class="inline-flex items-center w-fit hover:opacity-75 transition-opacity"
        onclick="selectMarketplaceFilter('{{ product.marketplace.slug }}')"
        aria-label="Filter by {{ product.marketplace.display_name or product.marketplace.name }}"
      >
        <img
          src="https://www.google.com/s2/favicons?domain={{ product.marketplace.domain }}&sz=128"
          alt="{{ product.marketplace.display_name or product.marketplace.name }}"
          class="h-5 w-5 rounded-sm object-contain"
          onerror="this.style.display='none'"
        >
      </button>
    {% endif %}

    {# Product name (click → modal) #}
    <button
      class="text-left text-sm font-semibold text-slate-800 dark:text-white line-clamp-2 hover:text-brand dark:hover:text-brand-hover transition-colors"
      onclick="openModalById('{{ product._id }}')"
    >
      {{ product.name }}
    </button>

    {# Category tags — link to that category's page #}
    {% if product.categories and product.categories.length %}
      <div class="flex flex-wrap gap-1">
        {% for cat in product.categories %}
          <a
            href="{{ (categoryBaseUrl if categoryBaseUrl else '/categories/') + (cat | lower) + '/' }}"
            class="text-[10px] font-medium px-2 py-0.5 rounded-full bg-slate-100 dark:bg-slate-700 text-slate-500 dark:text-slate-300 hover:bg-brand hover:text-white dark:hover:bg-brand-hover dark:hover:text-white transition-colors"
          >
            {{ cat | categoryDisplayName(categories) }}
          </a>
        {% endfor %}
      </div>
    {% endif %}

  </div>
</div>
{% endif %}
