{# _includes/bento-grid.njk
   Accepts: productList (array) — falls back to products.products if not set.
   Usage:  {% include "bento-grid.njk" %}
           {% set productList = someFilteredArray %}{% include "bento-grid.njk" %}
#}
{% set source = productList if productList else products.products %}
<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
  {% for product in source %}
    <div class="bg-white dark:bg-slate-800 rounded-3xl p-5 border border-slate-100 dark:border-slate-700 shadow-sm transition-all hover:shadow-md group">

      <div class="relative aspect-square overflow-hidden rounded-2xl bg-slate-100 dark:bg-slate-700 cursor-pointer"
           onclick='openModal({{ product | jsonify | safe }})'>
        {% if product.media and product.media[0] %}
          <img src="{{ product.media[0].url }}"
               alt="{{ product.name | escape }}"
               class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
        {% else %}
          <div class="w-full h-full flex items-center justify-center text-slate-400 dark:text-slate-500 text-sm">
            No Image
          </div>
        {% endif %}

        {% if product.media and product.media.length > 1 %}
          <span class="absolute top-3 right-3 bg-black/50 backdrop-blur-md text-white px-3 py-1 rounded-full text-xs font-medium pointer-events-none">
            +{{ product.media.length - 1 }} More
          </span>
        {% endif %}
      </div>

      <div class="mt-4">
        <h3 class="font-bold text-slate-900 dark:text-white text-base line-clamp-2 leading-tight">{{ product.name }}</h3>
        <p class="text-slate-500 dark:text-slate-400 text-sm mt-1 line-clamp-2">{{ product.description }}</p>
        <div class="flex items-center justify-end mt-4">
          <button onclick='openModal({{ product | jsonify | safe }})'
                  class="bg-slate-900 dark:bg-brand text-white px-4 py-2 rounded-xl text-sm font-bold hover:bg-brand-hover dark:hover:bg-brand-hover transition-colors">
            View Deal
          </button>
        </div>
      </div>

    </div>
  {% else %}
    <p class="text-slate-500 col-span-3">No products found.</p>
  {% endfor %}
</div>
