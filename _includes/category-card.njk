{# _includes/category-card.njk
   Requires: catName (string)
   Optional: productList, categoryBaseUrl
#}
{% set productSource = (productList if productList else products.products) | featuredFirst %}
{% set catUrl = (categoryBaseUrl if categoryBaseUrl else '/categories/') + (catName | lower) + '/' %}

{# Pre-count to decide whether to render the card at all #}
{% set totalCount = 0 %}
{% for product in productSource %}
  {% set matches = false %}
  {% for cat in product.categories %}
    {% if cat | lower == catName | lower %}{% set matches = true %}{% endif %}
  {% endfor %}
  {% if matches %}{% set totalCount = totalCount + 1 %}{% endif %}
{% endfor %}

{% if totalCount > 0 %}
<div class="bg-white dark:bg-slate-800 p-4 rounded-xl border border-slate-100 dark:border-slate-700 shadow-sm flex flex-col">
  <a href="{{ catUrl }}"
     class="text-lg font-bold text-slate-800 dark:text-white capitalize mb-4 hover:text-brand dark:hover:text-brand-hover transition-colors inline-block">
    {{ catName }}
  </a>

  <div class="grid grid-cols-2 gap-2 flex-1">
    {% set displayCount = 0 %}
    {% for product in productSource %}
      {% set matches = false %}
      {% for cat in product.categories %}
        {% if cat | lower == catName | lower %}{% set matches = true %}{% endif %}
      {% endfor %}
      {% if matches %}
        {% if displayCount < 4 %}
          {% set displayCount = displayCount + 1 %}
          {# Compact square thumbnail — intentionally not using product-card.njk to keep the rich card decoupled #}
          <div
            class="cursor-pointer group overflow-hidden rounded-lg border border-slate-200 dark:border-slate-700 aspect-square shadow-sm hover:shadow-md transition-all duration-300 bg-white dark:bg-slate-800"
            onclick='openModal({{ product | jsonify | safe }})'
          >
            {% if product.media and product.media[0] %}
              <img
                src="{{ product.media[0].url }}"
                alt="{{ product.name }}"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              >
            {% else %}
              <div class="w-full h-full bg-slate-100 dark:bg-slate-700 flex items-center justify-center text-xs text-slate-400 dark:text-slate-500">
                No Image
              </div>
            {% endif %}
          </div>
        {% endif %}
      {% endif %}
    {% endfor %}
  </div>

  {% if totalCount > 4 %}
    <a href="{{ catUrl }}"
       class="mt-4 block text-center text-sm font-semibold text-brand hover:text-brand-hover dark:hover:text-brand-hover transition-colors">
      Show all {{ totalCount }} →
    </a>
  {% endif %}
</div>
{% endif %}
