{# _includes/breadcrumbs.njk #}
{% set _segments = page.url | split('/') %}
{% set _firstSeg = '' %}
{% for _s in _segments %}
  {% if _s and not _firstSeg %}{% set _firstSeg = _s %}{% endif %}
{% endfor %}

{# If first segment is a country code → home = /{code}/, otherwise home = / #}
{% set _countryLabel = _firstSeg | codeToCountry(countries) %}
{% set _isCountryPath = (_countryLabel != _firstSeg) %}
{% set homeUrl = ('/' + _firstSeg + '/') if _isCountryPath else '/' %}

<nav class="px-4 sm:px-6 lg:px-8 pt-4 pb-2 text-sm text-slate-500 dark:text-slate-400">
  <ol class="flex items-center justify-start flex-wrap gap-y-1 gap-x-0">
    <li>
      <a href="{{ homeUrl }}"
         class="{% if page.url == homeUrl %}font-bold text-slate-800 dark:text-slate-100{% else %}hover:text-brand dark:hover:text-brand-hover{% endif %}">
        Home
      </a>
    </li>

    {% if page.url != homeUrl %}
      {% set currentPath = "" %}
      {% set prevSegment = "" %}
      {% for segment in _segments %}
        {% if segment != "" %}
          {% set currentPath = currentPath + "/" + segment %}

          {# Skip the country code segment — it's already represented by the Home link #}
          {% if _isCountryPath and segment == _firstSeg %}
            {# intentionally skipped #}
          {% else %}
            {% set label = segment | codeToCountry(countries) %}
            {% if label == segment %}
              {# Not a country code — apply human-readable overrides then fall back to slug-to-words #}
              {% if segment == 'new' %}
                {% set label = 'New this week' %}
              {% elif segment == 'wishlist' %}
                {% set label = 'Saved finds' %}
              {% elif segment == 'categories' %}
                {% set label = 'Categories' %}
              {% elif segment == 'marketplaces' %}
                {% set label = 'Marketplaces' %}
              {% elif prevSegment == 'categories' %}
                {% set label = segment | categoryDisplayName(categories) %}
              {% else %}
                {% set label = segment | replace("-", " ") %}
              {% endif %}
            {% endif %}

            <li class="flex items-center">
              <span class="mx-1.5 text-slate-300 dark:text-slate-600">/</span>
              {% if (currentPath + "/") == page.url %}
                <span class="capitalize font-semibold text-slate-700 dark:text-slate-200">{{ label }}</span>
              {% else %}
                <a href="{{ currentPath }}/"
                   class="capitalize hover:text-brand dark:hover:text-brand-hover transition-colors">
                  {{ label }}
                </a>
              {% endif %}
            </li>
          {% endif %}
          {% set prevSegment = segment %}
        {% endif %}
      {% endfor %}
    {% endif %}
  </ol>
</nav>
