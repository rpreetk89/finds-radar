<svg class="icon-svg w-full h-full" viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg">
  <style>
    .po{animation:pb 2.4s ease-in-out infinite;transform-box:fill-box;transform-origin:center;}
    @keyframes pb{0%,100%{transform:scale(1)}50%{transform:scale(1.18)}}
    .bk{animation:blink 2.4s ease-in-out infinite;}
    @keyframes blink{0%,35%,65%,100%{opacity:1}50%{opacity:0.15}}
  </style>
  <g transform="translate(30,30)">
    <circle cx="0" cy="0" r="24" stroke="#0D2545" stroke-width="2.5" fill="none"/>
    <circle cx="0" cy="0" r="15" stroke="#0D2545" stroke-width="1" fill="none" opacity="0.3"/>
    <line x1="0" y1="-30" x2="0" y2="-20" stroke="#0D2545" stroke-width="2.5" stroke-linecap="round"/>
    <line x1="0" y1="20" x2="0" y2="30" stroke="#0D2545" stroke-width="2.5" stroke-linecap="round"/>
    <line x1="-30" y1="0" x2="-20" y2="0" stroke="#0D2545" stroke-width="2.5" stroke-linecap="round"/>
    <line x1="20" y1="0" x2="30" y2="0" stroke="#0D2545" stroke-width="2.5" stroke-linecap="round"/>
    <g class="po">
      <path d="M0,-13 L2,-2 L0,0 L-2,-2 Z"  fill="#FF6B35"/>
      <path d="M13,0 L2,2 L0,0 L2,-2 Z"    fill="#FF6B35"/>
      <path d="M0,13 L-2,2 L0,0 L2,2 Z"    fill="#FF6B35"/>
      <path d="M-13,0 L-2,-2 L0,0 L-2,2 Z" fill="#FF6B35"/>
    </g>
    <circle cx="0" cy="0" r="2.8" fill="#0D2545"/>
    <circle cx="0" cy="0" r="1.4" fill="#FF6B35" class="bk"/>
  </g>
</svg>
