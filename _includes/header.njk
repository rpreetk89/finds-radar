<header class="sticky top-0 z-50 bg-white/80 dark:bg-slate-900/80 backdrop-blur-md border-b border-slate-200 dark:border-slate-800 transition-colors">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16 gap-4">

      <a href="/" id="nav-home-link" class="flex items-center shrink-0 font-bold text-lg tracking-tight text-slate-900 dark:text-white" aria-label="FindsRadar home">
        Finds<span class="text-brand">Radar</span>
      </a>

      <div class="flex items-center gap-2 shrink-0">

        {# Wishlist link #}
        <a href="/wishlist/" aria-label="Saved finds"
           class="w-9 h-9 flex items-center justify-center rounded-xl bg-slate-100 dark:bg-slate-800 hover:bg-orange-50 dark:hover:bg-slate-700 transition-colors">
          <svg class="w-5 h-5 text-slate-500 dark:text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
          </svg>
        </a>

        {# Country selector #}
        <details class="relative" id="country-details">
          <summary class="list-none cursor-pointer flex items-center gap-1.5 px-3 py-2 rounded-xl bg-slate-100 dark:bg-slate-800 text-sm font-medium hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors select-none">
            <img id="current-flag-img" src="" alt="" class="w-5 h-3.5 object-cover rounded-sm hidden">
            <span id="current-flag-fallback" class="text-xs font-bold uppercase">🌐</span>
            <span id="current-country-name" class="hidden sm:inline"></span>
            <svg class="w-3.5 h-3.5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </summary>
          <div class="absolute right-0 top-full mt-2 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl shadow-lg overflow-hidden z-50 min-w-[170px]">
            {% for c in countries %}
              {% if c.isDefault or c.showInNav %}
                <a href="/{{ c.code }}/"
                   data-country-code="{{ c.code }}"
                   data-country-default="{{ 'true' if c.isDefault else 'false' }}"
                   class="country-option flex items-center gap-3 px-4 py-2.5 text-sm text-slate-700 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors">
                  <img src="https://flagcdn.com/w20/{{ c.code }}.png"
                       srcset="https://flagcdn.com/w40/{{ c.code }}.png 2x"
                       alt="{{ c.name }}"
                       class="w-5 h-3.5 object-cover rounded-sm">
                  <span class="country-name">{{ c.name }}</span>
                </a>
              {% endif %}
            {% endfor %}
          </div>
        </details>

        {% include "theme-toggle.njk" %}
      </div>

    </div>
  </div>
</header>

<script>
  (function () {
    // Make logo link go to the active country home rather than root
    var firstSeg = window.location.pathname.split('/').filter(Boolean)[0] || '';
    if (/^[a-z]{2}$/.test(firstSeg)) {
      var homeLink = document.getElementById('nav-home-link');
      if (homeLink) homeLink.href = '/' + firstSeg + '/';
    }

    const path = window.location.pathname;
    const options = document.querySelectorAll('.country-option');
    let matched = false;

    options.forEach(function (el) {
      const code = el.dataset.countryCode;
      const isDefault = el.dataset.countryDefault === 'true';
      const isActive = path === '/' || path === '/index.html'
        ? isDefault
        : path.startsWith('/' + code + '/');

      if (isActive) {
        matched = true;
        el.classList.add('bg-orange-50', 'dark:bg-orange-900/20', 'font-semibold', 'text-brand-hover', 'dark:text-brand-hover');
        const name = el.querySelector('.country-name').textContent.trim();
        const flagImg = document.getElementById('current-flag-img');
        const fallback = document.getElementById('current-flag-fallback');
        flagImg.src = 'https://flagcdn.com/w20/' + code + '.png';
        flagImg.alt = name;
        flagImg.classList.remove('hidden');
        fallback.classList.add('hidden');
        document.getElementById('current-country-name').textContent = name;
      }
    });

    // Close dropdown when a country link is clicked
    document.querySelectorAll('.country-option').forEach(function (el) {
      el.addEventListener('click', function () {
        document.getElementById('country-details').removeAttribute('open');
      });
    });
  })();
</script>

