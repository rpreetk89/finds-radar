<header class="sticky top-0 z-50 bg-white/80 dark:bg-slate-900/80 backdrop-blur-md border-b border-slate-200 dark:border-slate-800 transition-colors">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      
    <a href="/" class="flex items-center">
        <img src="/images/light-logo.svg" alt="FindsRadar" class="h-10 w-auto block dark:hidden">
        <img src="/images/dark-logo.svg" alt="FindsRadar" class="h-10 w-auto hidden dark:block">
    </a>

      <div class="hidden md:flex flex-1 mx-8">
        <input type="text" placeholder="Search curated finds..." 
               class="w-full bg-slate-100 dark:bg-slate-800 border-none rounded-xl py-2 px-4 focus:ring-2 focus:ring-orange-500 text-sm">
      </div>

      <div class="flex items-center gap-4">
        {% include "theme-toggle.njk" %}
      </div>
    </div>
  </div>
</header>