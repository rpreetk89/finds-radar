<header class="sticky top-0 z-50 bg-white/80 dark:bg-slate-900/80 backdrop-blur-md border-b border-slate-200 dark:border-slate-800 transition-colors">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16 gap-4">

      <a href="/" class="flex items-center text-xl font-bold tracking-tight shrink-0">
        <span class="text-slate-900 dark:text-white">Finds</span>
        <span class="text-orange-500">Radar</span>
      </a>

      <div class="hidden md:flex flex-1 relative">
        <input id="search-input" type="text" placeholder="Search curated finds..."
          autocomplete="off"
          class="w-full bg-slate-100 dark:bg-slate-800 border-none rounded-xl py-2 px-4 focus:ring-2 focus:ring-orange-500 text-sm">
        <div id="search-results"
             class="hidden absolute top-full left-0 right-0 mt-1 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl shadow-lg overflow-hidden z-50 max-h-80 overflow-y-auto">
        </div>
      </div>

      <div class="flex items-center gap-2 shrink-0">

        {# Country selector #}
        <details class="relative" id="country-details">
          <summary class="list-none cursor-pointer flex items-center gap-1.5 px-3 py-2 rounded-xl bg-slate-100 dark:bg-slate-800 text-sm font-medium hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors select-none">
            <img id="current-flag-img" src="" alt="" class="w-5 h-3.5 object-cover rounded-sm hidden">
            <span id="current-flag-fallback" class="text-xs font-bold uppercase">🌐</span>
            <span id="current-country-name" class="hidden sm:inline"></span>
            <svg class="w-3.5 h-3.5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </summary>
          <div class="absolute right-0 top-full mt-2 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl shadow-lg overflow-hidden z-50 min-w-[170px]">
            {% for c in countries %}
              {% if c.isDefault or c.showInNav %}
                <a href="/{{ c.code }}/"
                   data-country-code="{{ c.code }}"
                   data-country-default="{{ 'true' if c.isDefault else 'false' }}"
                   class="country-option flex items-center gap-3 px-4 py-2.5 text-sm text-slate-700 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors">
                  <img src="https://flagcdn.com/w20/{{ c.code }}.png"
                       srcset="https://flagcdn.com/w40/{{ c.code }}.png 2x"
                       alt="{{ c.name }}"
                       class="w-5 h-3.5 object-cover rounded-sm">
                  <span class="country-name">{{ c.name }}</span>
                </a>
              {% endif %}
            {% endfor %}
          </div>
        </details>

        {% include "theme-toggle.njk" %}
      </div>

    </div>
  </div>
</header>

<script>
  (function () {
    const path = window.location.pathname;
    const options = document.querySelectorAll('.country-option');
    let matched = false;

    options.forEach(function (el) {
      const code = el.dataset.countryCode;
      const isDefault = el.dataset.countryDefault === 'true';
      const isActive = path === '/' || path === '/index.html'
        ? isDefault
        : path.startsWith('/' + code + '/');

      if (isActive) {
        matched = true;
        el.classList.add('bg-orange-50', 'dark:bg-orange-900/20', 'font-semibold', 'text-orange-600', 'dark:text-orange-400');
        const name = el.querySelector('.country-name').textContent.trim();
        const flagImg = document.getElementById('current-flag-img');
        const fallback = document.getElementById('current-flag-fallback');
        flagImg.src = 'https://flagcdn.com/w20/' + code + '.png';
        flagImg.alt = name;
        flagImg.classList.remove('hidden');
        fallback.classList.add('hidden');
        document.getElementById('current-country-name').textContent = name;
      }
    });

    // Close dropdown when a country link is clicked
    document.querySelectorAll('.country-option').forEach(function (el) {
      el.addEventListener('click', function () {
        document.getElementById('country-details').removeAttribute('open');
      });
    });
  })();
</script>

<script>
  (function () {
    var input = document.getElementById('search-input');
    var resultsEl = document.getElementById('search-results');
    if (!input || !resultsEl) return;

    // Detect current country from URL path (e.g. /ca/ → 'ca', / → 'us')
    var firstSeg = window.location.pathname.split('/').filter(Boolean)[0] || '';
    var countryCode = /^[a-z]{2}$/.test(firstSeg) ? firstSeg : 'us';

    var fuse = null;

    function initFuse() {
      if (fuse || !window.Fuse || !window.__FINDSRADAR_PRODUCTS) return;
      var scoped = window.__FINDSRADAR_PRODUCTS.filter(function (p) {
        return p.country && p.country.code === countryCode;
      });
      fuse = new window.Fuse(scoped, {
        keys: ['name', 'description'],
        threshold: 0.4,
        includeScore: true,
      });
    }

    function renderResults(hits) {
      if (!hits.length) {
        resultsEl.innerHTML = '<div class="px-4 py-3 text-sm text-slate-400">No results found.</div>';
        return;
      }
      resultsEl.innerHTML = hits.slice(0, 6).map(function (r) {
        var p = r.item;
        var safeData = JSON.stringify(p).replace(/"/g, '&quot;');
        return '<button onclick="openModal(' + safeData + '); document.getElementById(\'search-results\').classList.add(\'hidden\'); document.getElementById(\'search-input\').value = \'\';"'
          + ' class="w-full text-left px-4 py-2.5 hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors">'
          + '<div class="text-sm font-medium text-slate-900 dark:text-white">' + (p.name || '') + '</div>'
          + (p.price ? '<div class="text-xs text-slate-400 mt-0.5">' + p.price + '</div>' : '')
          + '</button>';
      }).join('');
    }

    input.addEventListener('input', function () {
      initFuse();
      var q = this.value.trim();
      if (!q) { resultsEl.classList.add('hidden'); return; }
      if (!fuse) { resultsEl.classList.add('hidden'); return; }
      renderResults(fuse.search(q));
      resultsEl.classList.remove('hidden');
    });

    document.addEventListener('click', function (e) {
      if (!input.contains(e.target) && !resultsEl.contains(e.target)) {
        resultsEl.classList.add('hidden');
      }
    });
  })();
</script>
