<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="{{ metaDescription if metaDescription else 'FindsRadar — hot finds, handpicked from top marketplaces.' }}">
    <title>{{ title if title else 'FindsRadar' }}</title>

    {# Favicon + app icons #}
    <link rel="icon" href="/images/icon-mark-static.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/images/icon-mark-static.svg">
    <link rel="manifest" href="/manifest.json">

    {# Open Graph #}
    <meta property="og:image" content="https://findsradar.com/images/logo-static-light.svg">
    <meta property="og:image:width" content="820">
    <meta property="og:image:height" content="240">

    <link rel="stylesheet" href="/assets/css/logo-styles.css">
    <style>
      /* ── Theme tokens — single source of truth for brand/accent colors ───── */
      :root {
        --color-brand: #FF6B35;
        --color-brand-hover: #E85A2A;
        --color-banner-from: #FFF7ED;
        --color-banner-to: #FFEDD5;
        --color-banner-text: #0f172a;
        --color-heart: #EF4444;
      }
      html.dark {
        --color-brand-hover: #FF8255;
        --color-banner-from: #1A3A6B;
        --color-banner-to: #0D2545;
        --color-banner-text: #ffffff;
        --color-heart: #F87171;
      }
    </style>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        darkMode: 'class',
        theme: {
          extend: {
            colors: {
              brand: { DEFAULT: 'var(--color-brand)', hover: 'var(--color-brand-hover)' },
              heart: 'var(--color-heart)',
            },
          },
        },
      };
    </script>
</head>
<body class="bg-white dark:bg-slate-900 text-slate-900 dark:text-white transition-colors duration-300 flex flex-col min-h-screen">

    {% include "header.njk" %}
    
    {# Add the breadcrumbs here #}
    
    {% include "breadcrumbs.njk" %}
    
    <main class="flex-1">
    {{ content | safe }}
    </main>

    {% include "footer.njk" %}

<div id="lightbox" class="fixed inset-0 z-[100] hidden bg-black/80 flex items-center justify-center p-4">
  <div class="bg-white dark:bg-slate-800 max-w-lg w-full rounded-3xl p-6 relative">
    <button onclick="closeModal()" class="absolute top-4 right-4 z-10 text-2xl font-bold leading-none text-slate-400 hover:text-slate-900 dark:hover:text-white">&times;</button>

    <h2 id="modal-title" class="text-xl font-bold text-slate-900 dark:text-white pr-8 mb-4 leading-snug"></h2>

    <div class="relative aspect-video w-full bg-slate-100 dark:bg-slate-700 rounded-2xl overflow-hidden mb-4 group">
      <div id="modal-media" class="w-full h-full"></div>

      <button id="prev-media" onclick="changeMedia(-1)" class="absolute left-2 top-1/2 -translate-y-1/2 bg-white/50 hover:bg-white p-2 rounded-full hidden items-center justify-center">
        ◀
      </button>

      <button id="next-media" onclick="changeMedia(1)" class="absolute right-2 top-1/2 -translate-y-1/2 bg-white/50 hover:bg-white p-2 rounded-full hidden items-center justify-center">
        ▶
      </button>
    </div>

    <p id="modal-desc" class="text-sm text-slate-600 dark:text-slate-300 min-h-[48px] mb-4 leading-relaxed"></p>

    <a id="modal-link" href="#" target="_blank" rel="noopener noreferrer"
       class="inline-flex items-center gap-2 px-5 py-2 bg-brand hover:bg-brand-hover text-white text-sm font-semibold rounded-lg transition-colors">
      Buy Now →
    </a>
  </div>
</div>

{# Inject product data for the lightbox and load the external script #}
<script>
  window.__FINDSRADAR_PRODUCTS = {{ products.products | jsonify | safe }};
</script>
<script src="https://cdn.jsdelivr.net/npm/fuse.js@7/dist/fuse.min.js"></script>
<script src="/assets/js/lightbox.js" defer></script>
<script src="/assets/js/search-filter.js" defer></script>
<script>
  const toggleBtn = document.getElementById('theme-toggle');
  const lightIcon = document.getElementById('theme-toggle-light-icon');
  const darkIcon = document.getElementById('theme-toggle-dark-icon');

  // Check initial preference
  if (localStorage.getItem('theme') === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
    document.documentElement.classList.add('dark');
    lightIcon.classList.remove('hidden');
    darkIcon.classList.add('hidden');
  } else {
    document.documentElement.classList.remove('dark');
  }

  // Toggle function
  toggleBtn.addEventListener('click', () => {
    document.documentElement.classList.toggle('dark');
    if (document.documentElement.classList.contains('dark')) {
      localStorage.setItem('theme', 'dark');
      lightIcon.classList.remove('hidden');
      darkIcon.classList.add('hidden');
    } else {
      localStorage.setItem('theme', 'light');
      lightIcon.classList.add('hidden');
      darkIcon.classList.remove('hidden');
    }
  });
</script>
</body>
</html>