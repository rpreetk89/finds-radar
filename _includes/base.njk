<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50 text-slate-900">
    
    {{ content | safe }}

    <div id="lightbox" class="fixed inset-0 z-[100] hidden bg-black/80 flex items-center justify-center p-4">
      <div class="bg-white max-w-lg w-full rounded-3xl p-6 relative">
        <button onclick="closeModal()" class="absolute top-4 right-4 text-3xl font-bold">&times;</button>
        <div id="modal-media" class="aspect-video w-full bg-slate-100 rounded-2xl overflow-hidden mb-4"></div>
        <h2 id="modal-title" class="text-2xl font-bold text-slate-900"></h2>
        <p id="modal-desc" class="text-slate-600 mt-2"></p>
        <a id="modal-link" href="#" target="_blank" class="block mt-6 bg-slate-900 text-white text-center py-3 rounded-xl font-bold">Buy Now</a>
      </div>
    </div>

<script>
  // Ensure products exist
  const allProducts = {{ products.products | dump | safe }};

  function openModal(index) {
    const product = allProducts[index];
    if (!product) return;
    document.getElementById('modal-title').innerText = product.name || "Product";
    document.getElementById('modal-desc').innerText = product.description || product.usp || "No description provided.";
    document.getElementById('modal-link').href = product.affiliate_link || "#";
    document.getElementById('modal-link').innerText = product.affiliate_link ? `Buy on marketplace` : `No link`;

    const media = (product.media && product.media[0]) ? product.media[0] : null;
    const container = document.getElementById('modal-media');
    container.innerHTML = "";

    if (media) {
      if (media.type === 'video') {
        container.innerHTML = `<video src="${media.url}" controls class="w-full h-full object-cover"></video>`;
      } else {
        container.innerHTML = `<img src="${media.url}" class="w-full h-full object-cover" alt="${product.name || 'Product image'}">`;
      }
    } else {
      container.innerHTML = `<div class="w-full h-full flex items-center justify-center text-slate-400">No media</div>`;
    }
      
    document.getElementById('lightbox').classList.remove('hidden');
  }

  function closeModal() {
    document.getElementById('lightbox').classList.add('hidden');
    const container = document.getElementById('modal-media');
    container.innerHTML = "";
  }
</script>
</body>
</html>