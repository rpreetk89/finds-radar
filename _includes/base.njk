<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="stylesheet" href="/assets/css/logo-styles.css">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <script>
      tailwind.config = {
        darkMode: 'class',
      }
    </script>
</head>
<body class="bg-white dark:bg-slate-900 text-slate-900 dark:text-white transition-colors duration-300">
    
    {% include "header.njk" %}

    {{ content | safe }}

<div id="lightbox" class="fixed inset-0 z-[100] hidden bg-black/80 flex items-center justify-center p-4">
  <div class="bg-white dark:bg-slate-800 max-w-lg w-full rounded-3xl p-6 relative">
    <button onclick="closeModal()" class="absolute top-4 right-4 z-10 text-3xl font-bold">&times;</button>
    
    <div class="relative aspect-video w-full bg-slate-100 dark:bg-slate-700 rounded-2xl overflow-hidden mb-4 group">
      <div id="modal-media" class="w-full h-full"></div>

      <button id="prev-media" onclick="changeMedia(-1)" class="absolute left-2 top-1/2 -translate-y-1/2 bg-white/50 hover:bg-white p-2 rounded-full hidden items-center justify-center">
        ◀
      </button>

      <button id="next-media" onclick="changeMedia(1)" class="absolute right-2 top-1/2 -translate-y-1/2 bg-white/50 hover:bg-white p-2 rounded-full hidden items-center justify-center">
        ▶
      </button>
    </div>

    <h2 id="modal-title" class="text-2xl font-bold text-slate-900 dark:text-white"></h2>
    <p id="modal-desc" class="text-slate-600 dark:text-slate-300 mt-2"></p>
    <a id="modal-link" href="#" target="_blank" rel="noopener noreferrer" class="block mt-6 bg-slate-900 dark:bg-orange-600 text-white text-center py-3 rounded-xl font-bold">Buy Now</a>
  </div>
</div>

{# Inject product data for the lightbox and load the external script #}
<script>
  window.__FINDSRADAR_PRODUCTS = {{ products.products | jsonify | safe }};
</script>
<script src="/assets/js/lightbox.js" defer></script>
<script>
  const toggleBtn = document.getElementById('theme-toggle');
  const lightIcon = document.getElementById('theme-toggle-light-icon');
  const darkIcon = document.getElementById('theme-toggle-dark-icon');

  // Check initial preference
  if (localStorage.getItem('theme') === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
    document.documentElement.classList.add('dark');
    lightIcon.classList.remove('hidden');
    darkIcon.classList.add('hidden');
  } else {
    document.documentElement.classList.remove('dark');
  }

  // Toggle function
  toggleBtn.addEventListener('click', () => {
    document.documentElement.classList.toggle('dark');
    if (document.documentElement.classList.contains('dark')) {
      localStorage.setItem('theme', 'dark');
      lightIcon.classList.remove('hidden');
      darkIcon.classList.add('hidden');
    } else {
      localStorage.setItem('theme', 'light');
      lightIcon.classList.add('hidden');
      darkIcon.classList.remove('hidden');
    }
  });
</script>
</body>
</html>