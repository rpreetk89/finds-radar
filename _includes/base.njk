<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50 text-slate-900">
    
    {{ content | safe }}

    <div id="lightbox" class="fixed inset-0 z-[100] hidden bg-black/80 flex items-center justify-center p-4">
      <div class="bg-white max-w-lg w-full rounded-3xl p-6 relative">
        <button onclick="closeModal()" class="absolute top-4 right-4 text-3xl font-bold" aria-label="Close modal">&times;</button>
        <div id="modal-media" class="aspect-video w-full bg-slate-100 rounded-2xl overflow-hidden mb-4"></div>
        <h2 id="modal-title" class="text-2xl font-bold text-slate-900"></h2>
        <p id="modal-desc" class="text-slate-600 mt-2"></p>
        <a id="modal-link" href="#" target="_blank" rel="noopener noreferrer" class="block mt-6 bg-slate-900 text-white text-center py-3 rounded-xl font-bold">Buy Now</a>
      </div>
    </div>

{# Inject product data for the lightbox and load the external script #}
<script>
  window.__FINDSRADAR_PRODUCTS = {{ products.products | jsonify }};
</script>
<script src="/assets/js/lightbox.js" defer></script>
</body>
</html>
