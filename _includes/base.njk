<div id="lightbox" class="fixed inset-0 z-[100] hidden bg-black/80 flex items-center justify-center p-4">
  <div class="bg-white max-w-lg w-full rounded-3xl p-6 relative">
    <button onclick="document.getElementById('lightbox').classList.add('hidden')" class="absolute top-4 right-4 text-2xl font-bold">&times;</button>
    
    <div id="modal-media" class="aspect-video w-full bg-slate-100 rounded-2xl overflow-hidden mb-4"></div>
    <h2 id="modal-title" class="text-2xl font-bold text-slate-900"></h2>
    <p id="modal-desc" class="text-slate-600 mt-2"></p>
    <a id="modal-link" href="#" target="_blank" class="block mt-6 bg-slate-900 text-white text-center py-3 rounded-xl font-bold">Buy Now</a>
  </div>
</div>

<script>
function triggerModal(element) {
  // Read the data from the 'data-product' attribute
  const rawData = element.getAttribute('data-product');
  const product = JSON.parse(rawData);
  
  const modal = document.getElementById('lightbox');
  const mediaContainer = document.getElementById('modal-media');
  
  document.getElementById('modal-title').innerText = product.name;
  document.getElementById('modal-desc').innerText = product.description || "No description provided.";
  document.getElementById('modal-link').href = product.affiliate_link;

  const media = product.media[0];
  mediaContainer.innerHTML = media.type === 'video' 
    ? `<video src="${media.url}" controls class="w-full h-full object-cover"></video>`
    : `<img src="${media.url}" class="w-full h-full object-cover">`;
  
  modal.classList.remove('hidden');
}
</script>