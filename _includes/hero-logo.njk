<!-- Added overflow-visible to prevent clipping of the radar rings -->
<div class="flex items-center gap-2 overflow-visible">
  
  <!-- Animated Icon -->
  <div class="block dark:hidden">{% include "svg/animated-light.njk" %}</div>
  <div class="hidden dark:block">{% include "svg/animated-dark.njk" %}</div>

  <!-- Text Wordmark -->
  <div class="flex flex-col">
    <div class="text-5xl font-bold tracking-tight">
      <span class="text-slate-900 dark:text-white">Finds</span><span class="text-orange-500">Radar</span>
    </div>
  </div>
</div>