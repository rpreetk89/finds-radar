---
pagination:
  data: collections.allCountryData
  size: 1
  alias: country
permalink: "/{{ country.code }}/index.html"
layout: base.njk
eleventyComputed:
  title: "FindsRadar — {{ country.name }}"
---

{# ── URL bases for this country ───────────────────────────────────────────── #}
{% if country.isDefault %}
  {% set mpBase = '/marketplaces/' %}
  {% set categoryBaseUrl = '/categories/' %}
{% else %}
  {% set mpBase = '/' + country.code + '/marketplaces/' %}
  {% set categoryBaseUrl = '/' + country.code + '/categories/' %}
{% endif %}
{% set newPageUrl = '/' + country.code + '/new/' %}

{# ── Country-scoped products ──────────────────────────────────────────────── #}
{% set countryProducts = products.products | filterByCountry(country.code) %}

{# ── Hero ─────────────────────────────────────────────────────────────────── #}
<section class="max-w-3xl mx-auto px-4 pt-4 pb-3 text-center">

  <div class="mb-2 flex justify-center">
    {% include "hero-logo.njk" %}
  </div>

  <h1 class="text-base md:text-lg font-semibold text-slate-500 dark:text-slate-400 mb-3 flex items-center justify-center gap-2 flex-wrap">
    <img src="https://flagcdn.com/w20/{{ country.code }}.png"
         srcset="https://flagcdn.com/w40/{{ country.code }}.png 2x"
         alt="{{ country.name }}"
         class="w-6 h-4 object-cover rounded-sm inline-block align-middle">
    Hot finds, handpicked.
  </h1>

  {# Search bar #}
  <div class="max-w-lg mx-auto mb-4">
    <input
      id="grid-search"
      type="text"
      placeholder="Search finds..."
      autocomplete="off"
      class="w-full bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl py-3 px-5 text-sm text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-brand transition"
    >
  </div>

  {# Marketplace filter chips for this country #}
  <div class="flex flex-wrap justify-center gap-2">
    {% for mp in country.marketplaces %}
      {% set mpCount = 0 %}
      {% for cat, items in mp.categories %}
        {% set mpCount = mpCount + items | length %}
      {% endfor %}
      {% if mpCount > 0 %}
        <button
          class="filter-chip px-3 py-1.5 rounded-full text-sm font-medium flex items-center gap-2"
          data-filter-mp="{{ mp.slug }}"
        >
          {% if mp.domain %}
            <img
              src="https://www.google.com/s2/favicons?domain={{ mp.domain }}&sz=128"
              alt=""
              class="h-5 w-5 rounded-sm object-contain flex-shrink-0"
              onerror="this.style.display='none'"
            >
          {% endif %}
          {{ mp.display_name or mp.name }}
        </button>
      {% endif %}
    {% endfor %}
  </div>

</section>

{# ── Global search empty state ───────────────────────────────────────────── #}
<div id="filter-empty" class="hidden text-center py-10 px-4"></div>

{# ── Flat search results (shown only when search is active) ───────────────── #}
<section id="search-results-section" class="hidden mb-10 px-4">
  <div class="product-row-wrapper">
    <div class="product-row" id="search-results-row"></div>
  </div>
</section>

{# ── Featured ──────────────────────────────────────────────────────────────── #}
{# DATA-SOURCE: sanity | featured flag (manual selection, max 10) #}
{% set pickProducts = countryProducts | topFeatured(10) %}
{% if pickProducts | length %}
<section data-section="top10" class="mb-10 py-6" style="background: linear-gradient(135deg, var(--color-banner-from) 0%, var(--color-banner-to) 100%);">
  <div class="px-4 mb-3 flex items-center gap-3">
    <h2 class="section-row-header" style="color:var(--color-banner-text);">
      <span style="color:var(--color-brand);">✦</span>&nbsp;Featured
    </h2>
  </div>
  <div class="product-row-wrapper">
    <div class="product-row px-4">
      {% for product in pickProducts %}
        {% include "product-card.njk" %}
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

{# ── Recent Additions — most recently added products, regardless of date #}
{% set thisWeekProducts = countryProducts | newestFirst | limit(10) %}
{% if thisWeekProducts | length %}
<section data-section="newthisweek" class="mb-10">
  <div class="px-4 mb-3 flex items-center gap-3">
    <a href="{{ newPageUrl }}" class="section-row-header">
      <span class="text-brand">✦</span>&nbsp;Recent Additions
    </a>
    <a href="{{ newPageUrl }}" class="see-all-link ml-auto">See all →</a>
  </div>
  <div class="product-row-wrapper">
    <div class="product-row px-4">
      {% for product in thisWeekProducts %}
        {% include "product-card.njk" %}
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

{# ── Category rows ─────────────────────────────────────────────────────────── #}
{% set catRows = countryProducts | categoryRows %}
{% for row in catRows %}
<section class="mb-10" id="cat-{{ row.slug }}">
  <div class="px-4 mb-3 flex items-center gap-3">
    <a href="{{ categoryBaseUrl }}{{ row.name | lower }}/" class="section-row-header capitalize">{{ row.name | categoryDisplayName(categories) }}</a>
    <a href="{{ categoryBaseUrl }}{{ row.name | lower }}/" class="see-all-link ml-auto">See all {{ row.totalCount }} →</a>
  </div>
  <div class="product-row-wrapper">
    <div class="product-row px-4">
      {% for product in row.products %}
        {% include "product-card.njk" %}
      {% endfor %}
    </div>
  </div>
</section>
{% else %}
<p class="text-center text-slate-500 dark:text-slate-400 py-12">No products found for {{ country.name }} yet.</p>
{% endfor %}
