---
pagination:
  data: collections.categoryPages
  size: 1
  alias: catPage
permalink: "{{ catPage.pageUrl }}index.html"
layout: base.njk
eleventyComputed:
  title: "{{ catPage.catDisplay }} Finds — FindsRadar"
---

<div class="max-w-7xl mx-auto px-4 py-8 text-slate-900 dark:text-white">

  {# Page header #}
  <div class="flex items-center justify-between mb-2">
    <h1 class="text-3xl font-bold capitalize">{{ catPage.catDisplay }}</h1>
    <a href="/{{ catPage.countryCode }}/" class="inline-flex items-center gap-2 text-sm text-slate-500 hover:text-orange-500 transition-colors">
      <img src="https://flagcdn.com/w20/{{ catPage.countryCode }}.png"
           srcset="https://flagcdn.com/w40/{{ catPage.countryCode }}.png 2x"
           alt="{{ catPage.countryName }}"
           class="w-5 h-3.5 object-cover rounded-sm">
      {{ catPage.countryName }}
    </a>
  </div>

  {# Live count — updated by JS as filters change #}
  <p class="text-slate-500 dark:text-slate-400 mb-6">
    <span id="filter-count">{{ catPage.products.length }} find{{ 's' if catPage.products.length != 1 else '' }}</span>
  </p>

  {# ── Filter bar ─────────────────────────────────────────────────────────── #}
  <div class="mb-6 space-y-3">

    {# Keyword search #}
    <input
      id="grid-search"
      type="text"
      placeholder="Search in {{ catPage.catDisplay }}..."
      autocomplete="off"
      class="w-full md:max-w-sm bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl py-2.5 px-4 text-sm text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-orange-500 transition block"
    >

    {# Marketplace chips — populated by JS from card data attributes (only shown when 2+ marketplaces exist) #}
    <div id="mp-chip-container" class="flex flex-wrap gap-2"></div>

  </div>

  {# Product grid #}
  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
    {% for product in catPage.products %}
      {% include "product-card.njk" %}
    {% else %}
      <p class="text-slate-500 col-span-4">No products yet.</p>
    {% endfor %}
  </div>

  <div id="filter-empty" class="hidden text-center py-10 px-4"></div>

</div>
