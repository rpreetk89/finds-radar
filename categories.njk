---
pagination:
  data: collections.customCategories
  size: 1
  alias: category
permalink: "/{{ category | slugify }}/index.html"
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ category | capitalize }} Finds | FindsRadar</title>
    <style>
        :root {
            --bg-color: #f8fafc; --card-bg: #ffffff; --text-main: #0f172a;
            --text-muted: #64748b; --accent: #ff4757; --accent-hover: #e03d4b;
            --radius: 16px; --shadow: 0 4px 20px -2px rgba(15, 23, 42, 0.05);
            --shadow-hover: 0 20px 25px -5px rgba(15, 23, 42, 0.1);
        }
        body { font-family: -apple-system, sans-serif; background-color: var(--bg-color); color: var(--text-main); margin: 0; padding: 0; }
        header { background: rgba(255, 255, 255, 0.8); backdrop-filter: blur(12px); position: sticky; top: 0; z-index: 100; border-bottom: 1px solid #e2e8f0; padding: 16px 24px; display: flex; justify-content: space-between; align-items: center; }
        .logo { font-size: 1.25rem; font-weight: 800; text-decoration: none; color: inherit; }
        .hero { max-width: 800px; margin: 60px auto 40px auto; text-align: center; padding: 0 20px; }
        .hero h1 { font-size: 3rem; font-weight: 900; letter-spacing: -1.5px; line-height: 1.1; margin-bottom: 16px; text-transform: capitalize; }
        .hero p { color: var(--text-muted); font-size: 1.25rem; }
        .filters { display: flex; justify-content: center; gap: 10px; flex-wrap: wrap; margin-bottom: 40px; }
        .pill { background: var(--card-bg); border: 1px solid #e2e8f0; padding: 8px 18px; border-radius: 100px; font-weight: 600; font-size: 0.9rem; text-decoration: none; color: inherit; }
        .pill:hover, .pill.active { background: var(--text-main); color: white; border-color: var(--text-main); }
        .feed-container { max-width: 1200px; margin: 0 auto; padding: 0 24px 80px 24px; }
        .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 30px; }
    </style>
</head>
<body>

    <header>
        <a href="/" class="logo">🛰️ FindsRadar</a>
        <a href="/" class="pill">Back Home</a>
    </header>

    <div class="hero">
        <h1>Trending {{ category | capitalize }} Finds</h1>
        <p>Curated list of top-rated items tagged under {{ category }} this week.</p>
        
        <div class="filters">
            <a href="/" class="pill">🔥 All Finds</a>
            <a href="/gadgets/" class="pill {% if category == 'gadgets' %}active{% endif %}">⚙️ Gadgets</a>
            <a href="/travel/" class="pill {% if category == 'travel' %}active{% endif %}">✈️ Travel</a>
            <a href="/home/" class="pill {% if category == 'home' %}active{% endif %}">🏠 Home</a>
        </div>
    </div>

    <main class="feed-container">
        <div class="grid">
            {% set itemsFound = false %}
            {% if products and products.products %}
                {% for product in products.products %}
                    {# Check for match - supporting both singular category and categories array #}
                    {% set isMatch = false %}
                        {% if product.category == category or (product.categories and category in product.categories) %}
                            {% set isMatch = true %}
                        {% endif %}

                    {% if isMatch %}
                    <div class="bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm overflow-hidden flex flex-col">
                        <div class="aspect-video bg-slate-100 dark:bg-slate-700 overflow-hidden">
                     {% if product.media and product.media[0].url %}
                        <img src="{{ product.media[0].url }}" alt="{{ product.name }}" class="w-full h-full object-cover">
                        {% endif %}
                    </div>
            
            <div class="p-4 flex flex-col flex-grow">
                <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-2">
                    {{ product.name }}
                </h3>
                <p class="text-slate-600 dark:text-slate-400 text-sm mb-4 flex-grow">
                    {{ product.description }}
                </p>
                
                        <div class="flex items-center justify-between pt-4 border-t border-slate-100 dark:border-slate-700 mt-auto">
                         <span class="text-xl font-black text-slate-900 dark:text-white">{{ product.price }}</span>
                         <a href="{{ product.affiliate_link }}" target="_blank" class="bg-orange-500 hover:bg-orange-600 text-white font-semibold px-4 py-2 rounded-xl text-sm transition-all">
                        Check Deal
                         </a>
                        </div>
                    </div>
                 </div>
                {% endif %}
            {% endfor %}
            {% endif %}
        </div>

        {# Safely evaluate if the collection was completely blank #}
        {% if not itemsFound %}
            <div style="text-align: center; width: 100%; grid-column: 1/-1; padding: 40px 0; color: var(--text-muted);">
                <p>No products listed in this category yet.</p>
            </div>
        {% endif %}
    </main>

</body>
</html>