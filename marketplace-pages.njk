---
pagination:
  data: collections.marketplaceGroups
  size: 1
  alias: group
permalink: "/marketplaces/{{ group.slug }}/index.html"
layout: base.njk
eleventyComputed:
  title: "FindsRadar — {{ group.name }}"
---

<div class="max-w-7xl mx-auto px-4 py-8 text-slate-900 dark:text-white">
  <h1 class="text-3xl font-bold mb-2 capitalize">{{ group.name }}</h1>
  <p class="text-slate-500 dark:text-slate-400 mb-8">Browse categories on {{ group.name }}</p>

  {% set categoryBaseUrl = '/categories/' %}
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
    {% for catName, items in group.categories %}
      {% set productList = items %}
      {% include "category-card.njk" %}
    {% else %}
      <p class="text-slate-500 col-span-4">No products yet for this marketplace.</p>
    {% endfor %}
  </div>
</div>
