---
pagination:
  data: collections.marketplaceGroups
  size: 1
  alias: group
permalink: "/marketplaces/{{ group.slug }}/index.html"
layout: base.njk
---

<div class="max-w-7xl mx-auto px-4 py-8 text-slate-900 dark:text-white"">
  <h1 class="text-3xl font-bold mb-8 capitalize">{{ group.name }}</h1>
  
  <p class="mb-6 text-slate-600 dark:text-slate-400">Browse categories for {{ group.name }}:</p>

  <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-6">
    {% for catName, items in group.categories %}
      <div class="p-6 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl shadow-sm hover:shadow-md transition">
        <h3 class="text-xl font-bold capitalize mb-4">{{ catName }}</h3>
        
        {# Show a preview of the items #}
        <div class="grid grid-cols-2 gap-2 mb-4">
           {% for product in items | limit(4) %}
             {% include "product-card.njk" %}
           {% endfor %}
        </div>
      
      {# Only show "View All" if there are more than 4 items #}
      {% if items.length > 4 %}
        <a href="/marketplaces/{{ group.name | slugify }}/{{ catName | slugify }}/" 
           class="text-indigo-600 font-semibold hover:underline">
           View All {{ items.length }} items →
        </a>
      {% endif %}
      </div>
    {% endfor %}
  </div>
</div>