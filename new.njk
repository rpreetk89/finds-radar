---
layout: base.njk
title: New This Week — FindsRadar
metaDescription: The latest finds added to FindsRadar, sorted by newest first.
---

{% set usProducts = products.products | filterByCountry('us') | newestFirst %}

<section class="max-w-7xl mx-auto px-4 pt-8 pb-16">

  <div class="mb-6 flex items-center gap-3">
    <h1 class="text-2xl font-bold text-slate-900 dark:text-white">
      <span class="text-brand">✦</span> New this week
    </h1>
    <span class="text-sm text-slate-400 dark:text-slate-500">{{ usProducts | length }} finds</span>
  </div>

  {# Search bar for this page #}
  <div class="max-w-sm mb-6">
    <input
      id="grid-search"
      type="text"
      placeholder="Search new finds..."
      autocomplete="off"
      class="w-full bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl py-2.5 px-4 text-sm text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-brand transition"
    >
  </div>

  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
    {% for product in usProducts %}
      {% include "product-card.njk" %}
    {% else %}
      <p class="col-span-5 text-slate-500 dark:text-slate-400 py-12 text-center">No products found.</p>
    {% endfor %}
  </div>

  <div id="filter-empty" class="hidden text-center py-10 px-4"></div>

</section>
