---
layout: base.njk
title: FindsRadar
---
<!-- Hero Section -->
<section class="max-w-7xl mx-auto px-4 py-16 md:py-24 flex flex-col items-center justify-center text-center">
  
  <div class="mb-6">
    {% include "hero-logo.njk" %}
  </div>

  <p class="text-lg text-slate-500 dark:text-slate-400 mb-8 font-medium">
    Hot finds, handpicked.
  </p>

  <button class="bg-orange-500 hover:bg-orange-600 text-white px-8 py-3 rounded-xl font-semibold transition-all">
    Browse Featured
  </button>

</section>

<div class="max-w-7xl mx-auto px-4 py-8">
  <h1 class="text-3xl font-bold mb-8">Categories</h1>

  <div class="grid md:grid-cols-2 gap-8">
    {% for cat in collections.customCategories %}
      {% set catName = cat %}
      {% include "category-card.njk" %}
    {% endfor %}
  </div>
</div>