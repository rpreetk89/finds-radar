---
layout: base.njk
title: FindsRadar
---

<div class="max-w-7xl mx-auto px-4 py-8">
  <h1 class="text-3xl font-bold mb-8">The Latest Finds</h1>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
    
    {% for item in products.products %}
      <div class="bg-white rounded-3xl p-5 border border-slate-100 shadow-sm flex flex-col">
        
        <div class="aspect-square overflow-hidden rounded-2xl bg-gray-200 mb-4">
          <img src="{{ item.media[0].url }}" alt="{{ item.name }}" class="w-full h-full object-cover">
        </div>

        <h3 class="font-bold text-lg text-slate-900 line-clamp-2">{{ item.name }}</h3>
        <p class="text-xl font-black mt-auto pt-4">{{ item.price }}</p>
        
        <a href="{{ item.affiliate_link }}" target="_blank" 
           class="mt-4 block bg-slate-900 text-white text-center py-2 rounded-xl font-bold hover:bg-slate-800">
           Check Deal
        </a>
      </div>
    {% endfor %}

  </div>
</div>