{% for item in products.products %}
  <div class="bg-white rounded-3xl p-5 border border-slate-100 shadow-sm">
    <div class="cursor-pointer aspect-square overflow-hidden rounded-2xl bg-slate-100" 
         onclick="openLightbox({{ item | dump | escape }})">
      <img src="{{ item.media[0].url }}" alt="{{ item.name }}" class="w-full h-full object-cover">
    </div>

    <h3 class="mt-4 font-bold text-slate-900 text-lg">{{ item.name }}</h3>
    <p class="text-xl font-black mt-2">{{ item.price }}</p>
    
    <button onclick="openLightbox({{ item | dump | escape }})" 
            class="w-full mt-4 bg-slate-900 text-white py-2 rounded-xl font-bold hover:bg-slate-800">
      Know More
    </button>
  </div>
{% endfor %}