---
layout: base.njk
title: FindsRadar
---
<section class="max-w-7xl mx-auto px-4 py-12 md:py-16 flex flex-col items-center justify-center text-center">
  <div class="mb-6">
    {% include "hero-logo.njk" %}
  </div>
  <p class="text-lg text-slate-500 dark:text-slate-400 mb-8 font-medium">
    Hot finds, handpicked.
  </p>
</section>

<section class="max-w-7xl mx-auto px-4 pb-12">
  <h2 class="text-xl font-bold mb-6">Shop by Marketplace</h2>
  <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
    {% for mp in collections.marketplaces %}
      {# Calculate count dynamically #}
      {% set count = 0 %}
      {% if products and products.products %}
        {% for item in products.products %}
          {% if item.marketplace == mp.data.name %}
            {% set count = count + 1 %}
          {% endif %}
        {% endfor %}
      {% endif %}

      <a href="/marketplaces/{{ mp.data.name | slugify }}/" class="btn">
        Shop {{ mp.data.name }} ({{ count }})
      </a>
    {% endfor %}
  </div>
</section>

<div class="max-w-7xl mx-auto px-4 pb-12">
  <h2 class="text-xl font-bold mb-6">Shop by Category</h2>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
    {% for cat in collections.customCategories %}
      {% set catName = cat %}
      {% include "category-card.njk" %}
    {% endfor %}
  </div>
</div>