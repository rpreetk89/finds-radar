---
layout: base.njk
title: FindsRadar
---

{# ── Data setup ───────────────────────────────────────────────────────────── #}
{% set usProducts = products.products | filterByCountry('us') %}

{# ── Hero ─────────────────────────────────────────────────────────────────── #}
<section class="max-w-3xl mx-auto px-4 pt-10 pb-6 text-center">

  <div class="mb-5 flex justify-center">
    {% include "hero-logo.njk" %}
  </div>

  <h1 class="text-3xl md:text-4xl font-bold text-slate-900 dark:text-white mb-2">
    Hot finds, handpicked.
  </h1>
  {# Search bar — filters cards across all rows #}
  <div class="max-w-lg mx-auto mb-4">
    <input
      id="grid-search"
      type="text"
      placeholder="Search finds..."
      autocomplete="off"
      class="w-full bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl py-3 px-5 text-sm text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-orange-500 transition"
    >
  </div>

  {# Marketplace filter chips — filter all rows by marketplace #}
  <div class="flex flex-wrap justify-center gap-2">
    {% for mp in marketplaces %}
      {% if mp.country.code == 'us' %}
        {% set mpCount = 0 %}
        {% for item in usProducts %}
          {% if item.marketplace and item.marketplace.slug == mp.slug %}
            {% set mpCount = mpCount + 1 %}
          {% endif %}
        {% endfor %}
        {% if mpCount > 0 %}
          <button
            class="filter-chip px-4 py-1.5 rounded-full text-sm font-medium"
            data-filter-mp="{{ mp.slug }}"
          >{{ mp.name }}</button>
        {% endif %}
      {% endif %}
    {% endfor %}
  </div>

</section>

{# ── Global search empty state ───────────────────────────────────────────── #}
<div id="filter-empty" class="hidden text-center py-10 px-4"></div>

{# ── Pick of the week ─────────────────────────────────────────────────────── #}
{# DATA-SOURCE: sanity | featured flag + _createdAt #}
{% set pickProducts = usProducts | topFeatured(6) %}
{% if pickProducts | length %}
<section class="mb-10 py-6" style="background: linear-gradient(135deg, #1A3A6B 0%, #0D2545 100%);">
  <div class="px-4 mb-3 flex items-center gap-3">
    <h2 class="section-row-header" style="color:#ffffff;">
      <span style="color:#FF6B35;">✦</span>&nbsp;Pick of the week
    </h2>
  </div>
  <div class="pick-carousel-wrapper product-row-wrapper">
    <div class="product-row px-4" id="pick-carousel">
      {% for product in pickProducts %}
        {% include "product-card.njk" %}
      {% endfor %}
    </div>
    <button class="pick-nav-btn pick-nav-prev" onclick="pickNav(-1)" aria-label="Previous">&#8249;</button>
    <button class="pick-nav-btn pick-nav-next" onclick="pickNav(1)" aria-label="Next">&#8250;</button>
  </div>
</section>
{% endif %}

{# ── New this week — only appears if products were actually added in the last 7 days #}
{% set thisWeekProducts = usProducts | addedWithinDays(7) | newestFirst | limit(8) %}
{% if thisWeekProducts | length %}
<section class="mb-10">
  <div class="px-4 mb-3 flex items-center gap-3">
    <a href="/us/new/" class="section-row-header">
      <span class="text-orange-500">✦</span>&nbsp;New this week
    </a>
    <span class="text-xs bg-orange-500 text-white px-2 py-0.5 rounded-full font-bold">{{ thisWeekProducts | length }}</span>
    <a href="/us/new/" class="see-all-link ml-auto">See all →</a>
  </div>
  <div class="product-row-wrapper">
    <div class="product-row px-4">
      {% for product in thisWeekProducts %}
        {% include "product-card.njk" %}
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

{# ── Category rows ─────────────────────────────────────────────────────────── #}
{% set catRows = usProducts | categoryRows %}
{% for row in catRows %}
<section class="mb-10" id="cat-{{ row.slug }}">
  <div class="px-4 mb-3 flex items-center gap-3">
    <a href="/categories/{{ row.name | lower }}/" class="section-row-header capitalize">{{ row.name }}</a>
    <a href="/categories/{{ row.name | lower }}/" class="see-all-link ml-auto">See all {{ row.totalCount }} →</a>
  </div>
  <div class="product-row-wrapper">
    <div class="product-row px-4">
      {% for product in row.products %}
        {% include "product-card.njk" %}
      {% endfor %}
    </div>
  </div>
</section>
{% else %}
<p class="text-center text-slate-500 dark:text-slate-400 py-12">No products found.</p>
{% endfor %}

<script>
(function () {
  var carousel = document.getElementById('pick-carousel');
  if (!carousel) return;
  var current = 0;
  var timer;

  function getCards() { return Array.from(carousel.querySelectorAll('.product-card')); }

  function scrollToCard(idx) {
    var cards = getCards();
    if (!cards.length) return;
    var n = cards.length;
    if (idx >= n) { carousel.scrollLeft = 0; current = 0; return; }
    current = ((idx % n) + n) % n;
    var pad = parseInt(getComputedStyle(carousel).paddingLeft) || 16;
    carousel.scrollTo({ left: cards[current].offsetLeft - pad, behavior: 'smooth' });
  }

  function startAuto() {
    clearInterval(timer);
    timer = setInterval(function () { scrollToCard(current + 1); }, 4000);
  }

  window.pickNav = function (dir) {
    clearInterval(timer);
    scrollToCard(current + dir);
    startAuto();
  };

  carousel.addEventListener('mouseenter', function () { clearInterval(timer); });
  carousel.addEventListener('mouseleave', startAuto);

  var touchX = 0;
  carousel.addEventListener('touchstart', function (e) {
    touchX = e.touches[0].clientX;
    clearInterval(timer);
  }, { passive: true });
  carousel.addEventListener('touchend', function (e) {
    var dx = e.changedTouches[0].clientX - touchX;
    if (Math.abs(dx) > 50) scrollToCard(current + (dx < 0 ? 1 : -1));
    startAuto();
  }, { passive: true });

  startAuto();
})();
</script>
